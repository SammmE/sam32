{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Clang + Ninja + vcpkg",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      },
      "environment": {
        "CC": "clang",
        "CXX": "clang++"
      }
    }
  ]
}
